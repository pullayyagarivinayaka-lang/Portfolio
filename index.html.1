<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PathWise — India's #1 Free Student Career Mentorship Platform</title>
<meta name="description" content="Free career guidance for every Indian student after 10th. B.Tech, MBBS, Pharmacy, Polytechnic, Arts — find your path with AI mentor and real experts.">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --primary: #1a56e8;
  --primary-dark: #1240c0;
  --accent: #f97316;
  --accent-light: #fff7ed;
  --bg: #f8faff;
  --bg-card: #ffffff;
  --text: #0f172a;
  --text-muted: #64748b;
  --text-light: #94a3b8;
  --border: #e2e8f0;
  --success: #16a34a;
  --success-bg: #f0fdf4;
  --warning: #d97706;
  --warning-bg: #fffbeb;
  --info: #0369a1;
  --info-bg: #f0f9ff;
  --radius: 12px;
  --radius-lg: 20px;
  --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.06);
  --shadow-lg: 0 8px 32px rgba(26,86,232,0.12);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; font-size: 16px; }
h1,h2,h3,h4 { font-family: 'Sora', sans-serif; font-weight: 700; line-height: 1.25; }

/* NAV */
nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  padding: 0 2rem;
}
.nav-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 64px; }
.nav-logo { font-family: 'Sora', sans-serif; font-weight: 700; font-size: 1.35rem; color: var(--primary); text-decoration: none; display: flex; align-items: center; gap: 8px; }
.nav-logo span { color: var(--accent); }
.nav-links { display: flex; gap: 1.5rem; list-style: none; }
.nav-links a { text-decoration: none; color: var(--text-muted); font-size: 0.9rem; font-weight: 500; transition: color 0.2s; }
.nav-links a:hover { color: var(--primary); }
.nav-cta { background: var(--primary); color: #fff; border: none; border-radius: 8px; padding: 10px 22px; font-size: 0.9rem; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; text-decoration: none; transition: background 0.2s; }
.nav-cta:hover { background: var(--primary-dark); }
.hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
.hamburger span { width: 24px; height: 2px; background: var(--text); border-radius: 2px; transition: all 0.3s; }

/* HERO */
.hero { max-width: 1200px; margin: 0 auto; padding: 5rem 2rem 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.hero-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--info-bg); color: var(--info); border: 1px solid #bae6fd; border-radius: 100px; padding: 6px 14px; font-size: 0.8rem; font-weight: 600; margin-bottom: 1.25rem; }
.hero-badge .dot { width: 7px; height: 7px; background: var(--primary); border-radius: 50%; animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
.hero h1 { font-size: 3rem; color: var(--text); margin-bottom: 1.25rem; }
.hero h1 em { color: var(--primary); font-style: normal; }
.hero p { color: var(--text-muted); font-size: 1.1rem; line-height: 1.75; margin-bottom: 2rem; }
.hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.btn-primary { background: var(--primary); color: #fff; border: none; border-radius: var(--radius); padding: 14px 28px; font-size: 1rem; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; text-decoration: none; transition: background 0.2s, transform 0.15s; display: inline-flex; align-items: center; gap: 8px; }
.btn-primary:hover { background: var(--primary-dark); transform: translateY(-1px); }
.btn-secondary { background: transparent; color: var(--primary); border: 1.5px solid var(--primary); border-radius: var(--radius); padding: 14px 28px; font-size: 1rem; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; text-decoration: none; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; }
.btn-secondary:hover { background: #eff6ff; }

/* HERO VISUAL */
.hero-visual { background: white; border-radius: var(--radius-lg); border: 1px solid var(--border); box-shadow: var(--shadow-lg); overflow: hidden; }
.hero-visual-header { background: var(--primary); color: white; padding: 1rem 1.25rem; font-size: 0.85rem; font-weight: 600; display: flex; align-items: center; gap: 8px; }
.hero-visual-body { padding: 1.25rem; }
.path-step { display: flex; align-items: flex-start; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--border); }
.path-step:last-child { border-bottom: none; }
.step-num { width: 28px; height: 28px; border-radius: 50%; background: var(--primary); color: white; font-size: 0.75rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
.step-num.accent { background: var(--accent); }
.path-step h4 { font-size: 0.85rem; font-family: 'Inter', sans-serif; font-weight: 600; }
.path-step p { font-size: 0.78rem; color: var(--text-muted); margin-top: 2px; }

/* STATS */
.stats-bar { background: var(--primary); padding: 2.5rem 2rem; }
.stats-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; text-align: center; }
.stat-item { color: white; }
.stat-item .num { font-family: 'Sora', sans-serif; font-size: 2.25rem; font-weight: 700; }
.stat-item .label { font-size: 0.85rem; opacity: 0.8; margin-top: 4px; }

/* SECTIONS */
.section { padding: 5rem 2rem; }
.section-inner { max-width: 1200px; margin: 0 auto; }
.section-label { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--primary); margin-bottom: 0.75rem; }
.section-title { font-size: 2.25rem; margin-bottom: 1rem; }
.section-sub { color: var(--text-muted); font-size: 1.05rem; max-width: 560px; line-height: 1.7; }

/* STATE & DEGREE SELECTOR */
.state-selector-section { background: linear-gradient(135deg, #1a56e8 0%, #7c3aed 100%); padding: 3rem 2rem; }
.state-selector-inner { max-width: 1200px; margin: 0 auto; text-align: center; }
.state-selector-inner h2 { color: white; font-size: 1.75rem; margin-bottom: 0.75rem; }
.state-selector-inner p { color: rgba(255,255,255,0.85); margin-bottom: 1.5rem; font-size: 1rem; }
.selector-row { display: flex; gap: 12px; max-width: 760px; margin: 0 auto; justify-content: center; flex-wrap: wrap; }
.selector-row select { flex: 1; padding: 12px 16px; border-radius: 10px; border: none; font-size: 0.95rem; font-family: 'Inter', sans-serif; outline: none; min-width: 220px; }
.selector-row button { background: var(--accent); color: white; border: none; border-radius: 10px; padding: 12px 24px; font-size: 0.95rem; font-weight: 700; cursor: pointer; font-family: 'Inter', sans-serif; transition: background 0.2s; white-space: nowrap; }
.selector-row button:hover { background: #ea6c00; }
.state-info-box { background: white; border-radius: var(--radius-lg); padding: 1.5rem 2rem; max-width: 900px; margin: 1.5rem auto 0; display: none; text-align: left; }
.state-info-box.visible { display: block; }
.state-info-box h3 { font-size: 1.1rem; color: var(--primary); margin-bottom: 0.5rem; }
.state-info-box .sdesc { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1rem; line-height: 1.65; }
.state-info-links { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 0.75rem; }
.state-link { font-size: 0.8rem; padding: 6px 14px; background: var(--info-bg); color: var(--info); border-radius: 100px; text-decoration: none; font-weight: 600; border: 1px solid #bae6fd; transition: all 0.2s; white-space: nowrap; }
.state-link:hover { background: var(--primary); color: white; border-color: var(--primary); }
.seats-box { margin-top: 1rem; background: var(--success-bg); border: 1px solid #bbf7d0; border-radius: var(--radius); padding: 1rem 1.25rem; }
.seats-box h4 { color: var(--success); font-size: 0.9rem; margin-bottom: 0.5rem; }
.seats-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; margin-top: 0.5rem; }
.seats-table th { background: #d1fae5; color: var(--success); padding: 6px 10px; text-align: left; font-weight: 700; }
.seats-table td { padding: 6px 10px; border-bottom: 1px solid #bbf7d0; color: var(--text-muted); }
.seats-table tr:last-child td { border-bottom: none; }
.degree-box { margin-top: 1rem; background: var(--info-bg); border: 1px solid #bae6fd; border-radius: var(--radius); padding: 1rem 1.25rem; }
.degree-box h4 { color: var(--info); font-size: 0.9rem; margin-bottom: 0.5rem; }
.degree-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 0.5rem; }
.degree-tag { font-size: 0.75rem; font-weight: 600; padding: 4px 12px; border-radius: 100px; background: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; cursor: pointer; transition: all 0.2s; }
.degree-tag:hover, .degree-tag.active { background: var(--primary); color: white; border-color: var(--primary); }
.degree-info-panel { display: none; margin-top: 1rem; background: white; border-radius: 10px; border: 1px solid var(--border); padding: 1rem 1.25rem; }
.degree-info-panel.show { display: block; }

/* PATHWAY SECTION */
.pathway-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; }
.pathway-card { background: white; border-radius: var(--radius-lg); border: 1px solid var(--border); box-shadow: var(--shadow); overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; }
.pathway-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.pathway-card-header { padding: 1.5rem 1.5rem 1rem; display: flex; align-items: center; gap: 12px; }
.pathway-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
.pathway-card h3 { font-size: 1.05rem; }
.pathway-card p { font-size: 0.85rem; color: var(--text-muted); margin-top: 4px; }
.pathway-card-body { padding: 0 1.5rem 1.5rem; }
.career-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 1rem; }
.tag { font-size: 0.75rem; font-weight: 500; padding: 4px 10px; border-radius: 100px; border: 1px solid; }
.tag-blue { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
.tag-green { background: #f0fdf4; color: #15803d; border-color: #bbf7d0; }
.tag-orange { background: #fff7ed; color: #c2410c; border-color: #fed7aa; }
.tag-purple { background: #faf5ff; color: #7c3aed; border-color: #e9d5ff; }
.tag-red { background: #fff1f2; color: #be123c; border-color: #fecdd3; }
.explore-btn { width: 100%; padding: 10px; background: transparent; color: var(--primary); border: 1.5px solid var(--primary); border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s; }
.explore-btn:hover { background: var(--primary); color: white; }

/* COLLEGES SECTION */
.colleges-section { background: white; }
.colleges-filter { display: flex; gap: 8px; flex-wrap: wrap; margin: 1.5rem 0; }
.filter-btn { padding: 8px 18px; border-radius: 8px; border: 1.5px solid var(--border); background: white; color: var(--text-muted); font-size: 0.85rem; font-weight: 500; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s; }
.filter-btn.active, .filter-btn:hover { background: var(--primary); color: white; border-color: var(--primary); }
.colleges-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin-top: 1.5rem; }
.college-card { background: var(--bg); border-radius: var(--radius); border: 1px solid var(--border); padding: 1.25rem 1.5rem; transition: transform 0.2s, box-shadow 0.2s; }
.college-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); background: white; }
.college-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 0.75rem; }
.college-rank { background: var(--primary); color: white; font-size: 0.7rem; font-weight: 700; padding: 3px 10px; border-radius: 100px; white-space: nowrap; flex-shrink: 0; }
.college-card h4 { font-size: 0.95rem; color: var(--text); line-height: 1.35; }
.college-card .college-loc { font-size: 0.78rem; color: var(--text-muted); margin: 3px 0 8px; }
.college-meta { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 0.75rem; }
.cmeta { font-size: 0.72rem; font-weight: 600; padding: 3px 9px; border-radius: 100px; }
.cmeta-type { background: #eff6ff; color: #1d4ed8; }
.cmeta-nirf { background: #fdf4ff; color: #7c3aed; }
.cmeta-fee { background: #f0fdf4; color: #15803d; }
.college-placements { background: white; border-radius: 8px; border: 1px solid var(--border); padding: 0.75rem 1rem; font-size: 0.78rem; }
.college-placements .plabel { font-weight: 700; color: var(--text); margin-bottom: 4px; font-size: 0.8rem; }
.p-row { display: flex; justify-content: space-between; color: var(--text-muted); margin-top: 3px; }
.p-val { font-weight: 700; color: var(--success); }
.p-val.high { color: var(--primary); }
.college-courses { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem; }
.college-courses strong { color: var(--text); }
.college-website { display: inline-flex; align-items: center; gap: 4px; font-size: 0.78rem; color: var(--primary); font-weight: 600; text-decoration: none; margin-top: 0.5rem; }
.college-website:hover { text-decoration: underline; }

/* ROADMAP SECTION */
.roadmap-section { background: white; }
.roadmap-tabs { display: flex; gap: 8px; margin: 2rem 0; flex-wrap: wrap; }
.tab-btn { padding: 10px 20px; border-radius: 8px; border: 1.5px solid var(--border); background: white; color: var(--text-muted); font-size: 0.875rem; font-weight: 500; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s; }
.tab-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
.tab-content { display: none; }
.tab-content.active { display: block; }
.roadmap-timeline { position: relative; padding-left: 3rem; }
.roadmap-timeline::before { content: ''; position: absolute; left: 1.1rem; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--primary), #e2e8f0); border-radius: 2px; }
.timeline-item { position: relative; margin-bottom: 2rem; }
.timeline-dot { position: absolute; left: -2.3rem; top: 0.3rem; width: 20px; height: 20px; border-radius: 50%; background: var(--primary); border: 3px solid white; box-shadow: 0 0 0 2px var(--primary); }
.timeline-item h4 { font-size: 1rem; font-family: 'Inter', sans-serif; font-weight: 600; }
.timeline-item .timeline-meta { display: flex; gap: 12px; margin: 6px 0; flex-wrap: wrap; }
.meta-pill { font-size: 0.75rem; font-weight: 600; padding: 3px 10px; border-radius: 100px; }
.meta-time { background: #eff6ff; color: #1d4ed8; }
.meta-type { background: #f0fdf4; color: #15803d; }
.timeline-item p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; }
.timeline-item ul { margin-top: 8px; padding-left: 1rem; font-size: 0.875rem; color: var(--text-muted); line-height: 1.9; }
.compare-box { background: #fffbeb; border: 1px solid #fcd34d; border-radius: var(--radius); padding: 1.25rem; margin-top: 2rem; }
.compare-box h4 { color: #92400e; font-size: 0.95rem; margin-bottom: 0.75rem; }
.compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.75rem; }
.compare-col h5 { font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem; font-family: 'Inter', sans-serif; }
.compare-col ul { padding-left: 1rem; font-size: 0.82rem; color: var(--text-muted); line-height: 1.8; }

/* AI CHAT SECTION */
.ai-section { background: linear-gradient(135deg, #f0f7ff 0%, #faf5ff 100%); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.ai-layout { display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: start; margin-top: 3rem; }
.ai-feature-list { list-style: none; display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }
.ai-feature { display: flex; align-items: flex-start; gap: 12px; background: white; border-radius: var(--radius); border: 1px solid var(--border); padding: 1rem; box-shadow: var(--shadow); }
.ai-feature-icon { width: 36px; height: 36px; border-radius: 8px; background: var(--info-bg); color: var(--info); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
.ai-feature h4 { font-size: 0.875rem; font-weight: 600; font-family: 'Inter', sans-serif; }
.ai-feature p { font-size: 0.8rem; color: var(--text-muted); margin-top: 2px; }

/* CHAT WIDGET */
.chat-widget { background: white; border-radius: var(--radius-lg); border: 1px solid var(--border); box-shadow: var(--shadow-lg); overflow: hidden; display: flex; flex-direction: column; height: 560px; }
.chat-header { background: var(--primary); padding: 1rem 1.25rem; display: flex; align-items: center; gap: 12px; }
.chat-avatar { width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }
.chat-header-info h4 { color: white; font-size: 0.95rem; font-family: 'Inter', sans-serif; font-weight: 600; }
.chat-header-info p { color: rgba(255,255,255,0.75); font-size: 0.78rem; }
.online-dot { width: 10px; height: 10px; background: #4ade80; border-radius: 50%; margin-left: auto; box-shadow: 0 0 0 2px rgba(74,222,128,0.3); animation: pulse 2s infinite; }
.chat-messages { flex: 1; overflow-y: auto; padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }
.msg { display: flex; gap: 8px; align-items: flex-start; }
.msg.user { flex-direction: row-reverse; }
.msg-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--primary); color: white; font-size: 0.7rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.msg.user .msg-avatar { background: var(--accent); }
.msg-bubble { max-width: 82%; padding: 10px 14px; border-radius: 16px; font-size: 0.875rem; line-height: 1.6; }
.msg.bot .msg-bubble { background: var(--bg); border: 1px solid var(--border); border-top-left-radius: 4px; color: var(--text); }
.msg.user .msg-bubble { background: var(--primary); color: white; border-top-right-radius: 4px; }
.quick-replies { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
.qr-btn { font-size: 0.78rem; padding: 6px 12px; border-radius: 100px; border: 1.5px solid var(--primary); background: white; color: var(--primary); cursor: pointer; font-family: 'Inter', sans-serif; font-weight: 500; transition: all 0.2s; white-space: nowrap; }
.qr-btn:hover { background: var(--primary); color: white; }
.chat-input-area { padding: 1rem; border-top: 1px solid var(--border); display: flex; gap: 8px; align-items: flex-end; }
.chat-input-area textarea { flex: 1; border: 1.5px solid var(--border); border-radius: 10px; padding: 10px 14px; font-size: 0.875rem; font-family: 'Inter', sans-serif; resize: none; outline: none; transition: border-color 0.2s; max-height: 120px; }
.chat-input-area textarea:focus { border-color: var(--primary); }
.send-btn { width: 42px; height: 42px; border-radius: 50%; background: var(--primary); color: white; border: none; cursor: pointer; font-size: 1.1rem; display: flex; align-items: center; justify-content: center; transition: background 0.2s; flex-shrink: 0; }
.send-btn:hover { background: var(--primary-dark); }
.thinking span { display: inline-block; width: 7px; height: 7px; background: var(--text-muted); border-radius: 50%; margin: 0 2px; animation: thinking 1.2s infinite; }
.thinking span:nth-child(2) { animation-delay: 0.2s; }
.thinking span:nth-child(3) { animation-delay: 0.4s; }
@keyframes thinking { 0%,80%,100%{transform:scale(0.8);opacity:0.5} 40%{transform:scale(1.2);opacity:1} }
.ai-powered-badge { display: inline-flex; align-items: center; gap: 6px; background: #faf5ff; color: #7c3aed; border: 1px solid #e9d5ff; border-radius: 100px; padding: 4px 12px; font-size: 0.75rem; font-weight: 600; margin-top: 0.5rem; }

/* QUIZ SECTION */
.quiz-section { background: white; }
.quiz-card { background: var(--bg); border-radius: var(--radius-lg); border: 1px solid var(--border); overflow: hidden; margin-top: 3rem; max-width: 680px; }
.quiz-progress { height: 4px; background: var(--border); }
.quiz-progress-fill { height: 100%; background: linear-gradient(to right, var(--primary), #7c3aed); transition: width 0.4s ease; border-radius: 4px; }
.quiz-inner { padding: 2.5rem; }
.quiz-step-label { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--primary); margin-bottom: 1rem; }
.quiz-question { font-size: 1.2rem; font-weight: 700; font-family: 'Sora', sans-serif; color: var(--text); margin-bottom: 1.5rem; }
.quiz-options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 2rem; }
.quiz-option { display: flex; align-items: flex-start; gap: 12px; padding: 14px 16px; background: white; border: 1.5px solid var(--border); border-radius: 10px; cursor: pointer; transition: all 0.2s; }
.quiz-option:hover { border-color: var(--primary); background: #eff6ff; }
.quiz-option.selected { border-color: var(--primary); background: #eff6ff; }
.quiz-option input { margin-top: 2px; accent-color: var(--primary); flex-shrink: 0; }
.quiz-actions { display: flex; gap: 10px; }
.quiz-result { background: white; border-radius: var(--radius-lg); border: 2px solid var(--primary); padding: 2rem; text-align: center; }
.result-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 1.25rem 0; }
