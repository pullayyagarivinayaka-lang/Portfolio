.modal { background: white; border-radius: var(--radius-lg); padding: 2rem; max-width: 540px; width: 100%; position: relative; max-height: 90vh; overflow-y: auto; }
.modal-close { position: sticky; top: 0; float: right; width: 32px; height: 32px; border-radius: 50%; background: var(--bg); border: 1px solid var(--border); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; margin-bottom: 1rem; }
.modal h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
