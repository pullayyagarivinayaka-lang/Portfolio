function openPath(key) {
  const d = pathDetails[key];
  if (!d) return;
  document.getElementById('pathModalContent').innerHTML = `<h3>${d.title}</h3>${d.content}`;
  document.getElementById('pathModal').classList.add('open');
}
function closePathModal() { document.getElementById('pathModal').classList.remove('open'); }

document.getElementById('bookingModal').addEventListener('click', function(e) { if(e.target === this) closeModal(); });
document.getElementById('pathModal').addEventListener('click', function(e) { if(e.target === this) closePathModal(); });

document.querySelectorAll('.quiz-option input').forEach(input => {
  input.addEventListener('change', function() {
    document.querySelectorAll(`input[name="${this.name}"]`).forEach(i => i.closest('.quiz-option').classList.remove('selected'));
    this.closest('.quiz-option').classList.add('selected');
  });
});
