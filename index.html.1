function showStateInfo() {
  const stateKey = document.getElementById('stateSelect').value;
  const degreeKey = document.getElementById('degreeSelect').value;
  const box = document.getElementById('stateInfoBox');
  const degBox = document.getElementById('degreeInfoBox');
  
  if (!stateKey && !degreeKey) { alert('Please select at least a State or a Degree Course!'); return; }

  box.classList.add('visible');

  if (stateKey && stateData[stateKey]) {
    const s = stateData[stateKey];
    document.getElementById('stateInfoTitle').textContent = s.name + ' — State Guide';
    document.getElementById('stateInfoDesc').textContent = s.desc;
    const linksDiv = document.getElementById('stateInfoLinks');
    linksDiv.innerHTML = s.links.map(l => `<a href="${l.url}" target="_blank" rel="noopener" class="state-link">${l.label} →</a>`).join('');

    // Seats
    if (s.seats) {
      const seatsBox = document.getElementById('degreeSeatsBox');
      seatsBox.innerHTML = `<div class="seats-box"><h4>🪑 Approximate Seat Availability in ${s.name}</h4><table class="seats-table"><thead><tr><th>Course</th><th>Approx Seats</th></tr></thead><tbody>${Object.entries(s.seats).map(([k,v])=>`<tr><td>${k}</td><td>${v}</td></tr>`).join('')}</tbody></table></div>`;
    }
  } else {
    document.getElementById('stateInfoTitle').textContent = 'Degree Course Information';
    document.getElementById('stateInfoDesc').textContent = '';
    document.getElementById('stateInfoLinks').innerHTML = '';
  }

  if (degreeKey && degreeData[degreeKey]) {
    const d = degreeData[degreeKey];
    degBox.style.display = 'block';
    document.getElementById('degreeInfoTitle').textContent = '🎓 ' + d.name;
    document.getElementById('degreeInfoText').textContent = '';
    document.getElementById('degreeSeatsBox').innerHTML = `
      <div class="seats-box"><h4>📋 Course Details</h4>
      <table class="seats-table"><thead><tr><th>Details</th><th>Info</th></tr></thead><tbody>
      <tr><td>Entrance Exam</td><td>${d.exam}</td></tr>
      <tr><td>Duration</td><td>${d.duration}</td></tr>
      <tr><td>Average Salary</td><td>${d.avg}</td></tr>
      <tr><td>Career Scope</td><td>${d.scope}</td></tr>
      <tr><td>Top Colleges</td><td>${d.top}</td></tr>
      </tbody></table></div>`;
  } else if (stateKey && stateData[stateKey] && stateData[stateKey].seats) {
    const s = stateData[stateKey];
    document.getElementById('degreeInfoBox').style.display = 'block';
    document.getElementById('degreeInfoTitle').textContent = '🪑 Seat Availability — ' + s.name;
    document.getElementById('degreeInfoText').textContent = '';
    document.getElementById('degreeSeatsBox').innerHTML = `<div class="seats-box"><table class="seats-table"><thead><tr><th>Course</th><th>Approx Seats</th></tr></thead><tbody>${Object.entries(s.seats).map(([k,v])=>`<tr><td>${k}</td><td>${v}</td></tr>`).join('')}</tbody></table></div>`;
  } else {
    degBox.style.display = 'none';
  }
}

