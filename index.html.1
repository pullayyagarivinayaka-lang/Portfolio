.mentor-languages { display: flex; gap: 4px; flex-wrap: wrap; justify-content: center; margin-bottom: 0.75rem; }
.lang-tag { font-size: 0.7rem; padding: 2px 8px; background: var(--success-bg); color: var(--success); border-radius: 100px; font-weight: 600; }
