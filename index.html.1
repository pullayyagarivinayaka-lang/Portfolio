let currentFilter = 'all';

function renderColleges(filter) {
  const grid = document.getElementById('collegesGrid');
  let filtered = colleges.filter(c => {
    if (filter === 'all') return true;
    return c.type === filter;
  });
  // Dedupe by name
  const seen = new Set();
  filtered = filtered.filter(c => { if(seen.has(c.name)) return false; seen.add(c.name); return true; });
  grid.innerHTML = filtered.map(c => `
    <div class="college-card">
      <div class="college-card-top">
        <h4>${c.name}</h4>
        <span class="college-rank">${c.rank}</span>
      </div>
      <div class="college-loc">📍 ${c.loc}</div>
      <div class="college-meta">
        <span class="cmeta cmeta-type">${c.type.toUpperCase()}</span>
        <span class="cmeta cmeta-nirf">NIRF ${c.nirf}</span>
        <span class="cmeta cmeta-fee">Fee ${c.fee}</span>
      </div>
      <div class="college-placements">
        <div class="plabel">🎯 Placement Details</div>
        <div class="p-row"><span>Average Package</span><span class="p-val">${c.avg}</span></div>
        <div class="p-row"><span>Highest Package</span><span class="p-val high">${c.high}</span></div>
        <div style="margin-top:5px;font-size:0.75rem;color:var(--text-muted)">Top Recruiters: ${c.recruiters}</div>
      </div>
      <div class="college-courses"><strong>Courses Offered:</strong> ${c.courses}</div>
      <a href="${c.website}" target="_blank" rel="noopener" class="college-website">🌐 Official Website →</a>
    </div>
  `).join('');
}

function filterColleges(filter, btn) {
  currentFilter = filter;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderColleges(filter);
}

renderColleges('all');

