let _mentorPhone = '', _mentorEmail = '';
function bookMentor(name, spec, phone, email) {
  _mentorPhone = phone; _mentorEmail = email;
  document.getElementById('mentorName').textContent = name;
  document.getElementById('mentorSpecialty').textContent = spec;
  document.getElementById('bookingModal').classList.add('open');
  updateBookBtns();
}
function updateBookBtns() {
  const name = document.getElementById('bookName').value.trim();
  const phone = document.getElementById('bookPhone').value.trim();
  const state = document.getElementById('bookState').value;
  const status = document.getElementById('bookStatus').value;
  const query = document.getElementById('bookQuery').value.trim();
  const time = document.getElementById('bookTime').value;
  const mentorName = document.getElementById('mentorName').textContent;
  const msg = encodeURIComponent(`Hi ${mentorName}, I'm ${name||'a student'} from ${state||'India'}.\n\nCurrent Status: ${status}\nQuery: ${query||'I need career guidance'}\nPreferred Time: ${time}\n\nPlease help me with my career planning.\n\n- ${name||'Student'} (PathWise)`);
  const waUrl = `https://wa.me/91${_mentorPhone}?text=${msg}`;
  const emailUrl = `mailto:${_mentorEmail}?subject=Career Guidance Session Request — PathWise&body=${encodeURIComponent(`Hi ${mentorName},\n\nName: ${name||'Student'}\nPhone: ${phone||'Not provided'}\nState: ${state||'Not specified'}\nStatus: ${status}\nQuery: ${query||'I need career guidance'}\nPreferred Time: ${time}\n\nPlease help me with my career planning.\nThank you!`)}`;
  document.getElementById('whatsappBookBtn').href = waUrl;
  document.getElementById('emailBookBtn').href = emailUrl;
}
['bookName','bookPhone','bookState','bookStatus','bookQuery','bookTime'].forEach(id => {
  document.getElementById(id).addEventListener('input', updateBookBtns);
  document.getElementById(id).addEventListener('change', updateBookBtns);
});
function closeModal() { document.getElementById('bookingModal').classList.remove('open'); }

